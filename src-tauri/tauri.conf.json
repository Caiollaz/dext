{
  "$schema": "https://raw.githubusercontent.com/niconiahi/schemas/master/tauri-v2.json",
  "productName": "Dext",
  "version": "2.0.4",
  "identifier": "com.dext.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "DEXT",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [],
        "section": "utils"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "shortDescription": "Local-first developer tools",
    "longDescription": "A collection of essential local tools for developers. JWT Decoder, Base64, UUID Generator, JSON Diff — all offline, zero backend, blazing fast.",
    "category": "DeveloperTool",
    "copyright": "Copyright 2026 DEXT"
  }
}
